{
  "manifest_version": 3,
  "name": "Hodei",
  "version": "1.0",
  "description": "Your wallet, simplified",
  "host_permissions": [
    "https://prod.api.ada-anvil.app/v2/services/*",
    "https://preprod.api.ada-anvil.app/v2/services/*",
    "https://bridge.hodei.io/api/dev/*"
  ],
  "content_scripts": [
    {
      "js": ["extension.js"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://*/*", "http://*/*"],
      "use_dynamic_url": true
    }
  ],
  "action": {
    "default_title": "Hodei",
    "default_icon": {
      "16": "images/hodei_16.png",
      "48": "images/hodei_48.png",
      "128": "images/hodei_128.png"
    }
  },
  "icons": {
    "16": "images/hodei_16.png",
    "48": "images/hodei_48.png",
    "128": "images/hodei_128.png"
  },
  "homepage_url": "https://hodei.io"
}
