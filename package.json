{
  "name": "hodei-client",
  "version": "0.0.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "private": true,
  "scripts": {
    "dev": "vite",
